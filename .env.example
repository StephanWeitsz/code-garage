DB_PGSQL_DATABASE=codegarage
DB_PGSQL_USERNAME=codeuser
DB_PGSQL_PASSWORD=yourpassword
DB_PGSQL_SSLMODE=prefer

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
